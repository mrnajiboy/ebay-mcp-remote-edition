{
  "name": "ebay-mcp-remote-edition",
  "version": "4.1.0",
  "description": "Remote + Local MCP server for eBay APIs - provides access to eBay developer functionality through MCP (Model Context Protocol)",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "ebay-mcp": "build/index.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "check-for-updates": "npx -y npm-check-updates",
    "update": "npx -y npm-check-updates -u && npm install",
    "playwright:install": "npx -y playwright@1.59.1 install chromium",
    "start": "node build/scripts/env-check.js node build/index.js",
    "start:http": "node build/scripts/env-check.js node build/server-http.js",
    "dev": "tsx src/scripts/env-check.ts tsx src/index.ts",
    "dev:http": "tsx src/scripts/env-check.ts tsx src/server-http.ts",
    "bootstrap:ebay-research-session": "node build/scripts/env-check.js node build/scripts/bootstrap-ebay-research-session.js",
    "research:bootstrap": "node build/scripts/env-check.js node build/scripts/bootstrap-ebay-research-session.js",
    "research:check-browser": "node build/scripts/env-check.js node build/scripts/check-playwright.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "setup": "tsx src/scripts/env-check.ts tsx src/scripts/setup.ts",
    "sync": "tsx src/scripts/dev-sync.ts",
    "diagnose": "tsx src/scripts/env-check.ts tsx src/scripts/diagnostics.ts",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && eslint . && prettier --check \"src/**/*.{ts,js,json,md}\"",
    "fix": "eslint . --fix && prettier --write \"src/**/*.{ts,js,json,md}\"",
    "prepare": "tsc && tsc-alias",
    "env:encrypt": "npx -y @dotenvx/dotenvx encrypt",
    "env:decrypt": "npx -y @dotenvx/dotenvx decrypt"
  },
  "keywords": [
    "mcp",
    "ebay",
    "ebay-api",
    "model-context-protocol",
    "ai-tools",
    "ai",
    "llm",
    "mcp",
    "documentation",
    "api",
    "ebay",
    "server",
    "backend"
  ],
  "author": "Kenyatta Naji Johnson-Adams",
  "license": "MIT",
  "files": [
    "build/**/*.js",
    "build/index.d.ts",
    "build/server-http.d.ts",
    "public/icons/*.png",
    "README.md",
    "docs/auth/production_scopes.json",
    "docs/auth/sandbox_scopes.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mrnajiboy/ebay-mcp-remote-edition.git"
  },
  "homepage": "https://github.com/mrnajiboy/ebay-mcp-remote-edition#readme",
  "bugs": {
    "url": "https://github.com/mrnajiboy/ebay-mcp-remote-edition/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@upstash/redis": "^1.37.0",
    "axios": "^1.14.0",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "dotenv-stringify": "^3.0.1",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.5.10",
    "flatted": "^3.4.2",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "playwright-core": "^1.59.1",
    "prompts": "^2.4.2",
    "update-notifier": "^7.3.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/prompts": "^2.4.9",
    "@types/supertest": "^7.2.0",
    "@types/update-notifier": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.14",
    "@vitest/ui": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "nock": "^14.0.12",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "hono@<4.12.7": ">=4.12.7",
      "flatted@<=3.4.1": ">=3.4.2"
    }
  }
}
