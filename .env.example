# eBay MCP Server Configuration
# Last Updated: Tuesday, March 17, 2026 at 02:44:43 PM GMT+9
# Environment: production

# =============================================================================
# LOCAL / STDIO MODE
# Classic single-user env-var auth used when running `pnpm start` locally.
# These are NOT used in hosted mode (use EBAY_CONFIG_FILE instead).
# =============================================================================

# Target eBay environment: "sandbox" or "production" (default: sandbox)
EBAY_ENVIRONMENT=sandbox

# Default environment for hosted OAuth flows: "sandbox" or "production".
# EBAY_ENVIRONMENT takes precedence if set.
EBAY_DEFAULT_ENVIRONMENT=sandbox

# eBay Developer App credentials — used for all environments unless the
# production/sandbox-specific variants below are set.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=

# Optional per-environment credential overrides.
# When set these take precedence over the generic EBAY_CLIENT_ID/SECRET above.
EBAY_PRODUCTION_CLIENT_ID=
EBAY_PRODUCTION_CLIENT_SECRET=
EBAY_PRODUCTION_REDIRECT_URI=
EBAY_SANDBOX_CLIENT_ID=
EBAY_SANDBOX_CLIENT_SECRET=
EBAY_SANDBOX_REDIRECT_URI=

# =============================================================================
# HOSTED / HTTP MODE (Render or similar)
# Used when running `pnpm run start:http`.
# =============================================================================

# Public URL of the deployed service (used in OAuth redirect callbacks).
PUBLIC_BASE_URL=

# Port the HTTP server listens on (Render sets this automatically).
PORT=

# Path to a Render Secret File containing per-environment eBay credentials.
# When present, overrides EBAY_CLIENT_ID / EBAY_CLIENT_SECRET / EBAY_REDIRECT_URI.
# See README for the expected JSON structure.
EBAY_CONFIG_FILE=/etc/secrets/ebay-config.json

# Optional shared secret that must be passed to /oauth/start to initiate OAuth.
# Prevents unauthorized users from starting an OAuth flow on your hosted server.
OAUTH_START_KEY=

# Admin API key — required for /admin/* endpoints.
ADMIN_API_KEY=

# Storage backend for OAuth state and user sessions.
# Options: "memory" (default, non-persistent) | "cloudflare-kv"
EBAY_TOKEN_STORE_BACKEND=memory

# User OAuth tokens (optional — enables higher-rate user-scoped API calls).
# Obtain via `pnpm run setup` or the hosted /oauth/* flow.
EBAY_USER_REFRESH_TOKEN=
EBAY_USER_ACCESS_TOKEN=
EBAY_APP_ACCESS_TOKEN=

# Cloudflare KV credentials (required when EBAY_TOKEN_STORE_BACKEND=cloudflare-kv).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_API_TOKEN=

# =============================================================================
# LOCALE (both modes)
# =============================================================================

EBAY_MARKETPLACE_ID=EBAY_US
EBAY_CONTENT_LANGUAGE=en-US

# =============================================================================
# LOGGING (both modes)
# =============================================================================

# Log verbosity: "error" | "warn" | "info" | "http" | "verbose" | "debug" | "silly"
EBAY_LOG_LEVEL=info

# Write logs to disk in addition to stdout: true | false (default: false).
EBAY_ENABLE_FILE_LOGGING=true
