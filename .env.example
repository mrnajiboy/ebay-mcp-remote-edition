# eBay MCP Server Configuration
# Copy to .env for local development.
# dotenvx is for local env workflows only.
# Hosted/server platforms should provide env vars directly.
# The standard local start/dev/setup/diagnose scripts auto-load `.env` via dotenvx.
# For encrypted local env management, you can use dotenvx:
#   pnpm run env:encrypt
#   pnpm run env:decrypt
#   pnpm run env:run -- pnpm run dev:http

# Target eBay environment: "sandbox" or "production" (default: sandbox)
EBAY_ENVIRONMENT=sandbox

# Default environment for hosted OAuth flows: "sandbox" or "production".
# EBAY_ENVIRONMENT takes precedence if set.
EBAY_DEFAULT_ENVIRONMENT=sandbox

# =============================================================================
# CREDENTIALS
# =============================================================================

# eBay Developer App credentials — used for all environments unless the
# production/sandbox-specific variants below are set.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RUNAME=

# EBAY_RUNAME is the eBay-generated RuName string (NOT a URL).
# It maps to the callback URL you registered in the eBay Developer Portal
# under "User Tokens → Add RuName".
# It is used as the redirect_uri parameter in eBay OAuth token-exchange calls.
# Example value: YourCompany-YourApp-SBX-abc123de4-56f78901

# Optional per-environment credential overrides.
# When set these take precedence over the generic variables above.
EBAY_PRODUCTION_CLIENT_ID=
EBAY_PRODUCTION_CLIENT_SECRET=
EBAY_PRODUCTION_RUNAME=

EBAY_SANDBOX_CLIENT_ID=
EBAY_SANDBOX_CLIENT_SECRET
EBAY_SANDBOX_RUNAME=

# Storage backend for OAuth state, user tokens, and session tokens.
# Options:
#   memory         = non-persistent, tests / throwaway local dev only
#   cloudflare-kv  = persistent multi-user storage via Cloudflare KV
#   upstash-redis  = persistent multi-user storage via Upstash Redis
EBAY_TOKEN_STORE_BACKEND=

# Cloudflare KV credentials (required when EBAY_TOKEN_STORE_BACKEND=cloudflare-kv).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_API_TOKEN=

# Upstash Redis credentials (required when EBAY_TOKEN_STORE_BACKEND=upstash-redis).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin API key — required for /admin/* endpoints.
ADMIN_API_KEY=

# =============================================================================
# LOCAL HTTPS OAUTH CALLBACK (local mode only)
#
# eBay requires an HTTPS callback URL. Use mkcert to create a locally-trusted
# certificate so you can run HTTPS on your dev machine.

# One-time setup:
#   brew install mkcert nss          # macOS (nss = Firefox support)
#   mkcert -install                  # install local CA into system trust store
#   mkcert ebay-local.test           # generates ebay-local.test.pem + ...-key.pem
#   echo "127.0.0.1  ebay-local.test" | sudo tee -a /etc/hosts

# In the eBay Developer Portal register callback URL:
#   https://ebay-local.test:3000/oauth/callback
# Copy the generated RuName string into EBAY_RUNAME (or EBAY_SANDBOX_RUNAME).

# Then fill in the three vars below:
# =============================================================================

# Paths to mkcert-generated certificate files.
# Required when local PUBLIC_BASE_URL starts with "https://".
EBAY_LOCAL_TLS_CERT_PATH=
EBAY_LOCAL_TLS_KEY_PATH=

# Public base URL used to construct the OAuth callback URL.
# For local HTTPS dev: https://ebay-local.test:3000
# For hosted/production deployment: https://your-domain.com
# Leave empty to use http://localhost:3000 (HTTP only — eBay will reject this
# for production RuNames).
PUBLIC_BASE_URL=https://ebay-local.test:3000

# =============================================================================
# HOSTED / HTTP MODE VARIABLES
# =============================================================================

# Optional; Render allows you to specify a Path to a Secret File containing 
# per-environment eBay credentials.
# When present, overrides EBAY_CLIENT_ID / EBAY_CLIENT_SECRET / EBAY_RUNAME.
# See README for the expected JSON structure.
EBAY_CONFIG_FILE=

# Optional host bind override for the HTTP server.
# Defaults to 0.0.0.0 in hosted mode.
MCP_HOST=

# Port override for the HTTP server (Servers usually set this automatically).
PORT=

# Optional shared secret that must be passed to /oauth/start to initiate OAuth.
# Prevents unauthorized users from starting an OAuth flow on your hosted server.
OAUTH_START_KEY=

# Node Build Version - Optional, defaults to >=22.x if not set. Used in Render's build environment.
NODE_VERSION=

# =============================================================================
# LOCALE
# =============================================================================

EBAY_MARKETPLACE_ID=EBAY_US
EBAY_CONTENT_LANGUAGE=en-US

# =============================================================================
# LOGGING
# =============================================================================

# Log verbosity: "error" | "warn" | "info" | "http" | "verbose" | "debug" | "silly"
EBAY_LOG_LEVEL=info

# Write logs to disk in addition to stdout: true | false (default: false).
EBAY_ENABLE_FILE_LOGGING=true

# =============================================================================
# LEGACY
# =============================================================================
# (legacy RUNAME fallbacks; now using EBAY_RUNAME)
EBAY_REDIRECT_URI= 
EBAY_PRODUCTION_REDIRECT_URI=
EBAY_SANDBOX_REDIRECT_URI=

# local file-token-store path used by the older single-user token store.
EBAY_TOKEN_STORE_PATH=

# User/app tokens for local single-user usage or explicit manual override flows.
# Hosted multi-user mode should persist tokens in Cloudflare KV or Upstash Redis,
# not in env variables.
EBAY_USER_REFRESH_TOKEN=
EBAY_USER_ACCESS_TOKEN=
EBAY_APP_ACCESS_TOKEN=

# EBAY_USER_REFRESH_TOKEN is the important long-lived credential.
# EBAY_USER_ACCESS_TOKEN is optional because it can be refreshed automatically.
